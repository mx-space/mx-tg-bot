{
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "dev": "npm run dev:watch",
    "dev:watch": "NODE_ENV=development tsx watch src/server.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prepare": "husky install",
    "start": "tsx src/server.ts",
    "start:prod": "NODE_ENV=production node dist/server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  },
  "dependencies": {
    "@fastify/cors": "8.5.0",
    "@fastify/env": "4.4.0",
    "@fastify/etag": "4.2.0",
    "@fastify/helmet": "11.1.1",
    "@fastify/multipart": "7.7.3",
    "@fastify/rate-limit": "8.1.1",
    "@fastify/sensible": "5.6.0",
    "@innei/next-async": "0.4.0",
    "@mx-space/api-client": "2.4.0",
    "@mx-space/webhook": "0.8.0",
    "@tanstack/query-core": "4.41.0",
    "axios": "1.15.0",
    "chalk": "4.1.2",
    "consola": "2.15.3",
    "cron": "2.4.4",
    "dayjs": "1.11.19",
    "dotenv": "16.6.1",
    "fastify": "4.29.1",
    "fastify-plugin": "4.5.1",
    "git-webhook-handler": "link:packages/git-webhook-handler",
    "husky": "8.0.3",
    "lodash": "4.18.1",
    "marked": "5.1.2",
    "randomcolor": "0.6.2",
    "remove-markdown": "0.6.3",
    "socket.io-client": "4.8.3",
    "telegraf": "4.16.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@innei/eslint-config-ts": "0.15.0",
    "@innei/prettier": "0.15.0",
    "@types/cron": "2.4.3",
    "@types/lodash": "4.17.24",
    "@types/marked": "5.0.2",
    "@types/node": "20.19.23",
    "@types/node-telegram-bot-api": "0.64.14",
    "@types/randomcolor": "0.5.9",
    "@types/remove-markdown": "0.3.4",
    "cross-env": "7.0.3",
    "eslint": "8.57.1",
    "fast-json-stringify": "5.16.1",
    "fastify-tsconfig": "1.0.1",
    "lint-staged": "13.3.0",
    "prettier": "3.8.1",
    "tsdown": "0.12.4",
    "tsx": "3.14.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.0"
}
